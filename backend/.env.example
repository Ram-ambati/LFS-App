# Backend Environment Variables
# Copy this file to .env and fill in actual values for your deployment

# PostgreSQL Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-db-password-here

# JWT Configuration
JWT_SECRET=your-very-long-random-secret-key-at-least-256-bits-for-hs256-must-be-changed
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=2592000000

# Hibernate Configuration
# For development: 'update' auto-creates/updates schema (dev-friendly)
# For production: 'validate' only checks schema consistency (use Flyway for migrations)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# File Upload Configuration
FILE_UPLOAD_DIR=uploads/

# Application Environment (development | production)
APP_ENVIRONMENT=development

# Frontend URL (used for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Cloudinary Configuration (for future file storage migration)
# See CLOUDINARY_MIGRATION_GUIDE.md for setup instructions
# Leave blank to use local filesystem (development only)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=lfs-app/uploads

# For Supabase PostgreSQL, use:
# SPRING_DATASOURCE_URL=jdbc:postgresql://db.supabase.co:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=<supabase-password>
#
# For production:
# APP_ENVIRONMENT=production
# FRONTEND_URL=https://your-frontend-vercel-url.com

