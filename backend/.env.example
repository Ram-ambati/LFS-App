# Backend Environment Variables
# Copy this file to .env and fill in actual values for your deployment

# PostgreSQL Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your-db-password-here

# JWT Configuration
JWT_SECRET=your-very-long-random-secret-key-at-least-256-bits-for-hs256-must-be-changed
JWT_ACCESS_TOKEN_EXPIRATION=3600000
JWT_REFRESH_TOKEN_EXPIRATION=2592000000

# Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# File Upload Configuration
FILE_UPLOAD_DIR=uploads/

# For Supabase PostgreSQL, use:
# SPRING_DATASOURCE_URL=jdbc:postgresql://db.supabase.co:5432/postgres
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=<supabase-password>
